# Root-level orchestration env (consumed by docker-compose).
# Copy to .env and adjust. Never commit real secrets.

# --- Postgres ---
POSTGRES_DB=hiwaloy
POSTGRES_USER=hiwaloy
POSTGRES_PASSWORD=change_me_local_only
POSTGRES_PORT=5432

# --- Chroma ---
CHROMA_PORT=8001

# --- Backend ---
BACKEND_PORT=8000
APP_ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_MB=8
IMAGE_RETENTION_HOURS=24
# Gemini key is required at AI implementation phase, not phase 0.
GEMINI_API_KEY=
GEMINI_MODEL=
EMBEDDING_MODEL=

# --- Frontend ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=HIWALOY
