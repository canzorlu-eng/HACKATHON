# ─────────────────────────────────────────────────────────────────
# HIWALOY — Environment Variable Template
# Copy to .env and fill in values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── Demo mode ──────────────────────────────────────────────────────
# true  → MockAI + in-memory reviews (no Gemini key or ChromaDB needed)
# false → requires GEMINI_API_KEY and running ChromaDB
DEMO_MODE=true

# --- Postgres ---
POSTGRES_DB=hiwaloy
POSTGRES_USER=hiwaloy
POSTGRES_PASSWORD=hiwaloy_local
POSTGRES_PORT=5433

# --- Chroma ---
CHROMA_PORT=8001

# --- Backend ---
BACKEND_PORT=8000
APP_ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_MB=8
IMAGE_RETENTION_HOURS=24
# Only required when DEMO_MODE=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
EMBEDDING_MODEL=

# --- Frontend ---
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=HIWALOY
