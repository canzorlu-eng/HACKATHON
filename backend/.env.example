# Backend env example. Copy to .env locally.
# Real secrets must never be committed.

APP_ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_MB=8
IMAGE_RETENTION_HOURS=24

# Storage
IMAGE_STORAGE_DIR=./var/images

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hiwaloy
POSTGRES_USER=hiwaloy
POSTGRES_PASSWORD=change_me_local_only

# Chroma
CHROMA_HOST=localhost
CHROMA_PORT=8001

# AI (required from Phase 3+, leave empty in Phase 0)
GEMINI_API_KEY=
GEMINI_MODEL=
EMBEDDING_MODEL=
