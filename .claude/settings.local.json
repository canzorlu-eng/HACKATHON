{
  "permissions": {
    "allow": [
      "Bash(dir *)",
      "Bash(npm --version)",
      "Bash(docker --version)",
      "Bash(python -m venv .venv)",
      "Bash(.venv/Scripts/python -m pip install --upgrade pip --quiet)",
      "Bash(.venv/Scripts/python -m pip install -r requirements.txt --quiet)",
      "Bash(npm install *)",
      "Bash(py -0)",
      "Bash(py -3.12 --version)",
      "Bash(py -3.13 --version)",
      "Bash(py -3.11 --version)",
      "Bash(npm run *)",
      "Bash(.venv/Scripts/python -m pip list)",
      "Bash(.venv/Scripts/python -m pytest)",
      "Bash(.venv/Scripts/python -m uvicorn app.main:app --host 127.0.0.1 --port 8765 --log-level warning)",
      "Bash(curl -fsS http://127.0.0.1:8765/openapi.json)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "ruflo"
  ]
}
